{
  "name": "Simulation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },

  "postCreateCommand": "pip install -r requirements.txt && python -m ipykernel install --user --name simulation-env --display-name \"Python (simulation-env)\""
}
