{
  "name": "Simulation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter", "ms-toolsai.jupyter-renderers", "ms-python.vscode-pylance"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.kernel.default": "python3"
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "python -m ipykernel install --user --name=python3 --display-name='Python 3 (Otomatis)'"
}
