{
  "name": "Simulation",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },

  "postCreateCommand": "pip install -r requirements.txt ipykernel && python -m ipykernel install --sys-prefix --name python3 --display-name \"Python 3 (Codespaces)\""
}
